# =============================================
# FreshBound — 環境変数テンプレート
# このファイルを .env.local にコピーして値を設定してください
# .env.local は .gitignore 済み（絶対にコミットしないこと）
# =============================================

# -----------------------------------------------
# Supabase（必須・全機能）
# Supabase ダッシュボード > Project Settings > API で確認
# -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase PostgreSQL 接続文字列
# ローカル開発: Project Settings > Database > Connection string > URI（port 5432）
# Vercel本番: Project Settings > Database > Connection pooling > Transaction mode（port 6543）を使用すること
# Transaction modeのURLは末尾に ?pgbouncer=true が付く場合あり
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase MCP（Claude Code の Supabase MCP サーバー用）
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# -----------------------------------------------
# OpenAI（F-05 AIメール生成）
# https://platform.openai.com/api-keys
# モデル: gpt-4o-mini を使用すること
# -----------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------
# SendGrid（F-06 メール配信・F-07 Webhook）
# https://app.sendgrid.com/settings/api_keys
# Webhook Secret は Settings > Mail Settings > Event Webhook で確認
# -----------------------------------------------
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com
SENDGRID_WEBHOOK_SIGNING_SECRET=

# -----------------------------------------------
# IMAP（F-07 返信検知）
# 送信元メールアカウントの IMAP 設定
# Gmail の場合: imap.gmail.com / 993 / アプリパスワードを使用
# -----------------------------------------------
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password

# -----------------------------------------------
# LINE Messaging API（F-08 ホットリード通知）
# https://developers.line.biz/console/
# -----------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# -----------------------------------------------
# Stripe（FB-01 請求・決済）
# https://dashboard.stripe.com/apikeys
# Webhook Secret は Stripe Dashboard > Webhooks で確認
# -----------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------
# 外部API
# -----------------------------------------------
# musubu API（F-02 企業発掘・F-03A 電話番号）
# https://musubu.in/
MUSUBU_API_KEY=

# hunter.io（F-03 担当者発掘）
# https://hunter.io/api-keys
HUNTER_API_KEY=

# WhoisXML API（F-02A 新規HP判定）
# https://user.whoisxmlapi.com/products
WHOISXML_API_KEY=
